from .. import loader, utils

@loader.tds
class AdminControlMod(loader.Module):
    """Управление доступом"""
    strings = {"name": "AdminControl"}

    async def client_ready(self, client, db):
        self._db = db

    @loader.unrestricted
    async def addadmincmd(self, message):
        """Добавить админа через реплей"""
        reply = await message.get_reply_message()
        if not reply:
            return await utils.answer(message, "Реплейни на того, кого хочешь добавить!")
        
        admins = self._db.get("hikka.main", "sudo", [])
        if reply.sender_id not in admins:
            admins.append(reply.sender_id)
            self._db.set("hikka.main", "sudo", admins)
            await utils.answer(message, f"Красава, ID {reply.sender_id} теперь в админах")
        else:
            await utils.answer(message, "Этот бро уже и так админ")
