from .. import loader, utils

@loader.tds
class sudomod(loader.Module):
    """sudo access management"""
    strings = {"name": "sudo"}

    async def client_ready(self, client, db):
        self._db = db

    @loader.unrestricted
    async def sudocmd(self, message):
        """add user to sudo via reply"""
        reply = await message.get_reply_message()
        if not reply:
            return await utils.answer(message, "reply to someone!")
        
        sudo_users = self._db.get("hikka.main", "sudo", [])
        if reply.sender_id not in sudo_users:
            sudo_users.append(reply.sender_id)
            self._db.set("hikka.main", "sudo", sudo_users)
            await utils.answer(message, f"user {reply.sender_id} added to sudo")
        else:
            await utils.answer(message, "already in sudo")
